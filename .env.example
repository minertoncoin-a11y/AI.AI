# Bu faylni .env nomi bilan saqlang va qiymatlarni to'ldiring

# Telegram bot tokeni (@BotFather dan oling)
BOT_TOKEN=8226841787:AAHKcEPAa0OIBHOpYwzOzJQZVEIZBLAYnDw

# OpenAI API kaliti (ixtiyoriy — AI yordami uchun)
# Agar yo'q bo'lsa, AI funksiyasi o'chiriladi
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# OpenAI modeli (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Admin Telegram ID lari (vergul bilan ajrating)
# Misol: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# Log darajasi: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Debug rejimi
DEBUG=False

# Kundalik AI so'rovlar limiti (har foydalanuvchi uchun)
AI_DAILY_LIMIT=30
